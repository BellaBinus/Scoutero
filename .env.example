# ── Database ──────────────────────────────────────────────────────────────────
# PostgreSQL connection string (Replit provides this automatically via the
# built-in Postgres integration; for local dev use your own instance)
DATABASE_URL=postgresql://user:password@localhost:5432/scoutero

# ── Clerk Authentication ───────────────────────────────────────────────────────
# Create a Clerk application at https://clerk.com and copy the keys below.
# The publishable key is safe to expose; the secret key must stay server-side.
CLERK_SECRET_KEY=sk_live_...
VITE_CLERK_PUBLISHABLE_KEY=pk_live_...

# Required when Clerk is proxied through your own domain (production only)
# Leave blank for local development
VITE_CLERK_PROXY_URL=
